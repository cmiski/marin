generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum IndexOperation {
  UPSERT
  DELETE
}

enum IndexEventStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(160)
  slug        String    @unique @db.VarChar(180)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("brands")
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(160)
  slug        String     @unique @db.VarChar(180)
  description String?
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("categories")
}

model Tag {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique @db.VarChar(80)
  slug      String       @unique @db.VarChar(100)
  products  ProductTag[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("tags")
}

model Product {
  id             String              @id @default(uuid()) @db.Uuid
  sku            String              @unique @db.VarChar(80)
  slug           String              @unique @db.VarChar(220)
  title          String              @db.VarChar(240)
  subtitle       String?             @db.VarChar(280)
  description    String?
  status         ProductStatus       @default(DRAFT)
  priceCents     Int                 @map("price_cents")
  currency       String              @default("USD") @db.Char(3)
  inventoryCount Int                 @default(0) @map("inventory_count")
  ratingAverage  Decimal             @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount    Int                 @default(0) @map("rating_count")
  attributes     Json                @default("{}")
  searchableText String?             @map("searchable_text")
  embedding      Float[]             @default([])
  publishedAt    DateTime?           @map("published_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")
  brandId        String?             @map("brand_id") @db.Uuid
  categoryId     String?             @map("category_id") @db.Uuid
  brand          Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category       Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           ProductTag[]
  variants       ProductVariant[]
  indexEvents    SearchOutboxEvent[]

  @@index([status, publishedAt])
  @@index([brandId])
  @@index([categoryId])
  @@index([updatedAt])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(uuid()) @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  sku            String   @unique @db.VarChar(100)
  title          String   @db.VarChar(220)
  priceCents     Int      @map("price_cents")
  inventoryCount Int      @default(0) @map("inventory_count")
  attributes     Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model ProductTag {
  productId String  @map("product_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
  @@map("product_tags")
}

model SearchIndexState {
  id            String    @id @default(uuid()) @db.Uuid
  indexName     String    @unique @map("index_name") @db.VarChar(120)
  aliasName     String    @map("alias_name") @db.VarChar(120)
  schemaVersion Int       @map("schema_version")
  lastIndexedAt DateTime? @map("last_indexed_at")
  lastIndexedId String?   @map("last_indexed_id") @db.Uuid
  documentCount Int       @default(0) @map("document_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("search_index_states")
}

model SearchOutboxEvent {
  id            String           @id @default(uuid()) @db.Uuid
  aggregateType String           @map("aggregate_type") @db.VarChar(80)
  aggregateId   String           @map("aggregate_id") @db.Uuid
  operation     IndexOperation
  payload       Json?
  status        IndexEventStatus @default(PENDING)
  attempts      Int              @default(0)
  errorMessage  String?          @map("error_message")
  availableAt   DateTime         @default(now()) @map("available_at")
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  product       Product?         @relation(fields: [aggregateId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("search_outbox_events")
}
